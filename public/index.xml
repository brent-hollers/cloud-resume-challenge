em; }&#xA;    .c-sec-title {&#xA;        font-family: &#39;Roboto&#39;, sans-serif;&#xA;        font-size: 0.75rem;&#xA;        font-weight: 700;&#xA;        letter-spacing: 0.15em;&#xA;        text-transform: uppercase;&#xA;        color: #1B2A6B;&#xA;        border-bottom: 1px solid #dde3f5;&#xA;        padding-bottom: 0.3rem;&#xA;        margin-bottom: 0.9rem;&#xA;    }&#xA;    .c-intro {&#xA;        font-family: &#39;Roboto&#39;, sans-serif;&#xA;        font-size: 0.9rem;&#xA;        color: #555;&#xA;        font-weight: 300;&#xA;        line-height: 1.7;&#xA;        margin-bottom: 1rem;&#xA;    }&#xA;&#xA;    /* Service cards */&#xA;    .svc-card {&#xA;        border: 1px solid #e0e6f8;&#xA;        border-radius: 4px;&#xA;        padding: 1.25rem;&#xA;        margin-bottom: 1rem;&#xA;        background: white;&#xA;    }&#xA;    .svc-card.featured { border-color: #1B2A6B; background: #E8F0FE; }&#xA;    .svc-card h4 {&#xA;        font-family: &#39;Roboto Slab&#39;, serif;&#xA;        font-size: 0.97rem;&#xA;        color: #1B2A6B;&#xA;        margin-bottom: 0.4rem;&#xA;    }&#xA;    .svc-card .desc {&#xA;        font-family: &#39;Roboto&#39;, sans-serif;&#xA;        font-size: 0.85rem;&#xA;        color: #666;&#xA;        font-style: italic;&#xA;        font-weight: 300;&#xA;        margin-bottom: 0.65rem;&#xA;        line-height: 1.6;&#xA;    }&#xA;    .svc-card ul { margin: 0 0 0.65rem 1.1rem; padding: 0; }&#xA;    .svc-card ul li {&#xA;        font-family: &#39;Roboto&#39;, sans-serif;&#xA;        font-size: 0.83rem;&#xA;        color: #444;&#xA;        font-weight: 300;&#xA;        margin-bottom: 0.2rem;&#xA;        line-height: 1.5;&#xA;    }&#xA;    .rate {&#xA;        display: inline-block;&#xA;        font-family: &#39;Roboto&#39;, sans-serif;&#xA;        font-size: 0.78rem;&#xA;        font-weight: 700;&#xA;        color: #0D7A5F;&#xA;        background: rgba(13,122,95,0.08);&#xA;        padding: 0.15rem 0.5rem;&#xA;        border-radius: 2px;&#xA;    }&