: 0.15em;&#xA;        text-transform: uppercase;&#xA;        color: #1B2A6B;&#xA;        border-bottom: 1px solid #dde3f5;&#xA;        padding-bottom: 0.3rem;&#xA;        margin-bottom: 0.9rem;&#xA;    }&#xA;    .r-summary {&#xA;        font-family: &#39;Roboto&#39;, sans-serif;&#xA;        font-size: 0.9rem;&#xA;        color: #555;&#xA;        font-weight: 300;&#xA;        line-height: 1.7;&#xA;    }&#xA;&#xA;    /* Outcomes */&#xA;    .outcomes-grid {&#xA;        display: grid;&#xA;        grid-template-columns: 1fr 1fr;&#xA;        gap: 0.6rem;&#xA;    }&#xA;    @media (max-width: 500px) { .outcomes-grid { grid-template-columns: 1fr; } }&#xA;    .outcome-pill {&#xA;        background: #E8F0FE;&#xA;        border-left: 3px solid #1B2A6B;&#xA;        padding: 0.5rem 0.75rem;&#xA;        border-radius: 0 3px 3px 0;&#xA;        font-family: &#39;Roboto&#39;, sans-serif;&#xA;        font-size: 0.83rem;&#xA;        color: #333;&#xA;        font-weight: 300;&#xA;    }&#xA;    .outcome-pill strong { color: #1B2A6B; font-weight: 700; }&#xA;&#xA;    /* Job entries */&#xA;    .r-job { margin-bottom: 1.5rem; }&#xA;    .r-job-hdr {&#xA;        display: flex;&#xA;        justify-content: space-between;&#xA;        align-items: flex-start;&#xA;        flex-wrap: wrap;&#xA;        gap: 0.2rem;&#xA;    }&#xA;    .r-job-title {&#xA;        font-family: &#39;Roboto Slab&#39;, serif;&#xA;        font-size: 0.97rem;&#xA;        font-weight: 700;&#xA;        color: #222;&#xA;    }&#xA;    .r-job-dates {&#xA;        font-family: &#39;Roboto&#39;, sans-serif;&#xA;        font-size: 0.8rem;&#xA;        color: #999;&#xA;        white-space: nowrap;&#xA;    }&#xA;    .r-job-org {&#xA;        font-family: &#39;Roboto&#39;, sans-serif;&#xA;        font-size: 0.85rem;&#xA;        color: #777;&#xA;        font-style: italic;&#xA;        margin-bottom: 0.5rem;&#xA;    }&#xA;    .r-sub {&#xA;        font-family: &#39;Roboto&#39;, sans-serif;&#xA;        font-size: 0.75rem;&#xA;        font-weight: 700;&#xA;        color: #1B2A6B;&#xA;        text-transform: uppercase;&#xA;        letter-spacing: 0.07em;&#xA;        margin: 0.75rem 0 0.35rem;&#xA;    }&#xA;    .r-ul { list-style: none; margin: 0; padding: 0; }&#xA;    .r-ul li {&#xA;        font-family: &#39;Roboto&#39;, sans-serif;&#xA;        font-size: 0.85rem;&#xA;        color: #555;&#xA;        font-weight: 300;&#xA;        padding: 0.2rem 0 0.2rem 1.1rem;&#xA;        position: relative;&#xA;        line-height: 1.6;&#xA;    }&#xA;    .r-ul li::before { content: &#39;→&#39;; position: absolute; left: 0; color: #1B2A6B; font-size: 0.78rem; top: 0.28rem; }&#xA;&#xA;    /* Prior */&#xA;    .prior-row {&#xA;        display: flex;&#xA;        justify-content: space-between;&#xA;        align-items: baseline;&#xA;        padding: 0.35rem 0;&#xA;        border-bottom: 1px dotted #e0e0e0;&#xA;        flex-wrap: wrap;&#xA;        gap: 0.2rem;&#xA;    }&#xA;    .prior-title { font-family: &#39;Roboto&#39;, sans-serif; font-size: 0.85rem; font-weight: 500; color: #333; }&#xA;    .prior-org { font-family: &#39;Roboto&#39;, sans-serif; font-size: 0.8rem; color: #888; font-style: italic; }&#xA;    .prior-dates { font-family: &#39;Roboto&#39;, sans-serif; font-size: 0.78rem; color: #aaa; }&#xA;&#xA;    /* Skills */&#xA;    .skills-tbl { width: 100%; border-collapse: collapse; }&#xA;    .skills-tbl td {&#xA;        font-family: &#39;Roboto&#39;, sans-serif;&#xA;        font-size: 0.83rem;&#xA;        padding: 0.38rem 0.5rem;&#xA;        vertical-align: top;&#xA;        border-bottom: 1px solid #f0f0f0;&#xA;        color: #555;&#xA;        font-weight: 300;&#xA;        line-height: 1.55;&#xA;    }&#xA;    .skills-tbl td:first-child {&#xA;        font-weight: 700;&#xA;        color: #1B2A6B;&#xA;        white-space: nowrap;&#xA;        width: 20%;&#xA;        padding-right: 1rem;&#xA;    }&#xA;&#xA;    /* Education */&#xA;    .edu-row {&#xA;        display: flex;&#xA;        justify-content: space-between;&#xA;        align-items: baseline;&#xA;        padding: 0.45rem 0;&#xA;        border-bottom: 1px solid #f0f0f0;&#xA;        flex-wrap: wrap;&#xA;        gap: 0.2rem;&#xA;    }&#xA;    .edu-deg { font-family: &#39;Roboto&#39;, sans-serif; font-size: 0.88rem; font-weight: 600; color: #222; }&#xA;    .edu-inst { font-family: &#39;Roboto&#39;, sans-serif; font-size: 0.82rem; color: #888; font-style: italic; }&#xA;&#xA;    /* Certs */&#xA;    .certs-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 0.45rem; }&#xA;    @media (max-width: 500px) { .certs-grid { grid-template-columns: 1fr; } }&#xA;    .cert-item {&#xA;        display: flex;&#xA;        align-items: center;&#xA;        gap: 0.45rem;&#xA;        font-family: &#39;Roboto&#39;, sans-serif;&#xA;        font-size: 0.83rem;&#xA;        color: #444;&#xA;        font-weight: 300;&#xA;    }&#xA;    .badge-active { background: rgba(13,122,95,0.12); color: #0D7A5F; font-size: 0.68rem; font-weight: 700; padding: 0.12rem 0.45rem; border-radius: 2px; white-space: nowrap; }&#xA;    .badge-prog { background: rgba(27,42,107,0.1); color: #1B2A6B; font-size: 0.68rem; font-weight: 700; padding: 0.12rem 0.45rem; border-radius: 2px; white-space: nowrap; }&#xA;&#xA;    @media print {&#xA;        .resume-actions, #menu-pane, footer { display: none !important; }&#xA;    }&#xA;    &lt;/style&gt;&#xA;&lt;/head&gt;&#xA;&lt;body lang=&#34;en-US&#34;&gt;&#xA;&lt;div class=&#34;container my-auto&#34;&gt;&#xA;&#xA;&lt;header class=&#34;text-start title&#34;&gt;&#xA;    &lt;h1 class=&#34;title&#34;&gt;Resume&lt;/h1&gt;&#xA;&lt;/header&gt;&#xA;&#xA;&lt;section id=&#34;content-pane&#34;&gt;&#xA;&lt;div class=&#34;text-justify content&#34;&gt;&#xA;&#xA;&lt;div class=&#34;resume-actions&#34;&gt;&#xA;    &lt;a href=&#34;http://localhost:1313/resume.pdf&#34; class=&#34;btn-dl&#34; download&gt;⬇ Download PDF&lt;/a&gt;&#xA;    &lt;a href=&#34;javascript:window.print()&#34; class=&#34;btn-pr&#34;&gt;🖨 Print&lt;/a&gt;&#xA;&lt;/div&gt;&#xA;&#xA;&lt;!-- HEADER --&gt;&#xA;&lt;div class=&#34;r-header&#34;&gt;&#xA;    &lt;div class=&#34;r-name&#34;&gt;BRENT HOLLERS, Ph.D.&lt;/div&gt;&#xA;    &lt;div class=&#34;r-subtitle&#34;&gt;Technical Program Manager &amp;nbsp;·&amp;nbsp; Cloud Infrastructure &amp;nbsp;·&amp;nbsp; IT Security &amp;nbsp;·&amp;nbsp; AWS Certified Solutions Architect&lt;/div&gt;&#xA;    &lt;div class=&#34;r-contact&#34;&gt;&#xA;        &lt;span&gt;Sharpsburg, GA 30277&lt;/span&gt;&#xA;        &lt;a href=&#34;https://linkedin.com/in/brenthollers&#34;&gt;linkedin.com/in/brenthollers&lt;/a&gt;&#xA;        &lt;a href=&#34;https://www.brenthollers.com&#34;&gt;brenthollers.com&lt;/a&gt;&#xA;        &lt;a href=&#34;https://github.com/brent-hollers&#34;&gt;github.com/brent-hollers&lt;/a&gt;&#xA;    &lt;/div&gt;&#xA;&lt;/div&gt;&#xA;&#xA;&lt;!-- SUMMARY --&gt;&#xA;&lt;div class=&#34;r-sec&#34;&gt;&#xA;    &lt;div class=&#34;r-sec-title&#34;&gt;Professional Summary&lt;/div&gt;&#xA;    &lt;p class=&#34;r-summary&#34;&gt;Technical Program Manager with 5+ years of end-to-end program ownership across cloud infrastructure, network architecture, cybersecurity, and software delivery — managing concurrent workstreams, cross-functional stakeholders, budgets, and vendor relationships with full accountability for outcomes. Delivered $250K+ in cost savings, achieved STEM accreditation 4 years ahead of schedule, and built production AWS infrastructure using Terraform, GitHub Actions CI/CD, EC2, RDS, Lambda, S3, CloudFront, Glue, Athena, and EventBridge. AWS Certified Solutions Architect – Associate. PMP and CompTIA Security+ in progress.&lt;/p&gt;</description>
